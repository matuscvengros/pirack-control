# Docker image name. Defaults to local build. Uncomment below to pull pre-built from GHCR.
# PIRACK_IMAGE=ghcr.io/matuscvengros/pirack-control:latest

PORT=3000

# UDM Pro connection for the Network (WAN) module. Any of these can instead be
# set on the /config page. Setting them here keeps the secret out of config.json
# and lets a server be configured entirely from .env.
# UDM_API_KEY=your-readonly-api-key
# UDM_HOST=192.168.1.1
# UDM_SITE=default

UDM_HOST=
UDM_API_KEY=